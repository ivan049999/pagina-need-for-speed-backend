NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Supabase / Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# Supabase → Settings → API (service_role secret, solo backend)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Auth (opcional)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Storage
UPLOAD_MAX_SIZE_MB=5
STORAGE_PUBLIC_URL=http://localhost:4000/uploads

# Resend (correos de verificación)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="Need for Speed <onboarding@resend.dev>"

# Twilio (SMS al móvil — verificación de teléfono)
# 1) Crea cuenta gratis: https://www.twilio.com/try-twilio
# 2) Console → Account Info: copia Account SID y Auth Token
# 3) Phone Numbers → Buy/Get a number (debe poder enviar SMS)
# 4) Cuenta Trial: Phone Numbers → Verified Caller IDs → añade tu móvil (+34...)
# Sin estas variables el código solo aparece en la consola del backend.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
